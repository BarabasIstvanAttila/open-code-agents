{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "theme": "opencode",
  "model": "omlx/gemma-4-e4b-it-4bit",
  "small_model": "opencode-go/deepseek-v4-flash",
  "default_agent": "dev",
  "autoupdate": true,
  "lsp": true,
  "snapshot": true,
  "instructions": ["AGENTS.md"],
  "permission": {
    "bash": {
      "*": "allow",
      "git push --force*": "ask",
      "git push * --force*": "ask",
      "git reset --hard*": "ask",
      "rm -rf *": "deny",
      "rm *": "deny"
    },
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow"
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", ".agent/**"]
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "mdnsDomain": "myproject.local",
    "cors": ["http://localhost:5173"]
  },
  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8005/v1",
        "apiKey": "{env:OMLX_API_KEY}"
      },
      "models": {
        "Qwen3.5-9B-OptiQ-4bit": {
          "name": "Qwen3.5-9B-OptiQ-4bit",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "gemma-4-e4b-it-4bit": {
          "name": "gemma-4-e4b-it-4bit",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    },
    "opencode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1/chat/completions"
      },
      "models": {
        "glm-5.1": {
          "name": "opencode-go/glm-5.1",
          "limit": {
            "context": 202752,
            "output": 131072
          }
        },
        "qwen3.7-plus": {
          "name": "opencode-go/qwen3.7-plus",
          "limit": {
            "context": 202752,
            "output": 131072
          }
        },
        "deepseek-v4-flash": {
          "name": "opencode-go/deepseek-v4-flash",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "nemotron-3-super-free": {
          "name": "opencode-go/nemotron-3-super-free",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "deepseek-v4-flash-free": {
          "name": "opencode-go/deepseek-v4-flash-free",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7API}"
      },
      "enabled": true
    },
    "duckduckgo": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "mcp/duckduckgo"],
      "enabled": true
    },
    "sequentialthinking": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "mcp/sequentialthinking"],
      "enabled": true
    },
    "qmd": {
      "type": "local",
      "command": ["bunx", "@tobilu/qmd", "mcp"],
      "enabled": true
    }
  },
  "tools": {
    "sequentialthinking*": true,
    "context7*": true,
    "duckduckgo*": true,
    "context-mode*": true,
    "qmd*": true
  },
  "plugin": [
    "context-mode"
  ]
}